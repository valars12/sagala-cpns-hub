# Server
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://sagala_bimbel_app:<password>@localhost:5432/sagalabimbel?schema=public"
JWT_SECRET="<random-min-16-char>"
TOKEN_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5174,http://localhost:5173"
FRONTEND_URL="http://localhost:5174"

# Midtrans
MIDTRANS_SERVER_KEY="<midtrans-server-key>"
MIDTRANS_CLIENT_KEY="<midtrans-client-key>"
MIDTRANS_IS_PRODUCTION=false

# Note:
# - Di cPanel Node.js App production, JANGAN isi PORT manual di UI env.
# - Biarkan Passenger/cPanel mengisi PORT otomatis.
